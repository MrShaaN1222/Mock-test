{
  "name": "ssc-cbt-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed": "npm run seed --workspace backend",
    "seed:admin": "npm run seed:admin --workspace backend",
    "seed:questions": "npm run seed:questions --workspace backend",
    "seed:questions:reset": "npm run seed:questions:reset --workspace backend",
    "seed:reset": "npm run seed:reset --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3"
  }
}
