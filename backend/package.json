{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo \"No backend build step required\"",
    "test": "node --test",
    "lint": "eslint .",
    "seed:admin": "node src/seeds/admin.seed.js",
    "seed:questions": "node src/seeds/questions.seed.js",
